# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env.local
.env.vercel
supabase/.temp/
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Bubblewrap / Android — secrets and build outputs
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/*.keystore
android/app-release-*.aab
android/app-release-*.apk
android/app-release-*.idsig
android/app-release-unsigned-aligned.apk
android/manifest-checksum.txt
android/store_icon.png
