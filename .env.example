NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CELITECH_CLIENT_ID=
CELITECH_CLIENT_SECRET=
CRON_SECRET=
STRIPE_WEBHOOK_SECRET=
ESIM_ENCRYPTION_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_STRIPE_MOCK=true

# Set to "true" only after configuring Sign in with Apple in Supabase + Apple Developer.
# Hides the Apple OAuth button when unset/false so users don't click a broken provider.
NEXT_PUBLIC_OAUTH_APPLE_ENABLED=false

# Push Notifications (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_PUSH_MOCK=true

# Apple Push Notifications (APNs) — used by the iOS app to deliver
# native push from the backend. The .p8 file is downloaded once from
# developer.apple.com → Keys; paste its full contents (including the
# BEGIN/END PRIVATE KEY lines) into APN_PRIVATE_KEY as a single string
# with literal "\n" between lines, OR use base64 if your hosting
# environment requires single-line values.
APN_KEY_ID=
APN_TEAM_ID=
APN_BUNDLE_ID=co.esimpanda.app
APN_PRIVATE_KEY=
